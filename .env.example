# API
API_PORT=3000                              # Required. Port for the Hono API server.
CORS_ORIGIN=http://localhost:5173          # Required. Allowed origin for CORS.
NODE_ENV=development                       # Optional. "development" | "production" | "test". Default: "development".

# Database
# Pre-configured for docker-compose. No app code wires this yet —
# add a Drizzle or Prisma client when you need persistence.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forgekit

# Frontend (Vite injects vars prefixed with VITE_)
VITE_API_URL=http://localhost:3000         # Required by web app to reach the API.
